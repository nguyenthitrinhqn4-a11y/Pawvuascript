local function createSlider(name, icon, min, max, default, callback)
    local frame = Instance.new("Frame")
    frame.Parent = scrollFrame
    frame.Size = UDim2.new(1, -10, 0, 65)
    frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    frame.BackgroundTransparency = 0.82
    frame.ZIndex = 99
    frame.BorderSizePixel = 0
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = frame
    
    local iconLbl = Instance.new("TextLabel")
    iconLbl.Parent = frame
    iconLbl.Size = UDim2.new(0, 26, 0, 24)
    iconLbl.Position = UDim2.new(0, 12, 0, 4)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text = icon
    iconLbl.TextSize = 16
    iconLbl.Font = Enum.Font.GothamMedium
    iconLbl.TextColor3 = Color3.fromRGB(60, 25, 45)
    iconLbl.ZIndex = 99
    
    local txtLbl = Instance.new("TextLabel")
    txtLbl.Parent = frame
    txtLbl.Size = UDim2.new(0, 230, 0, 24)
    txtLbl.Position = UDim2.new(0, 42, 0, 4)
    txtLbl.BackgroundTransparency = 1
    txtLbl.Text = name .. ": " .. default
    txtLbl.TextSize = 12
    txtLbl.Font = Enum.Font.GothamSemibold
    txtLbl.TextColor3 = Color3.fromRGB(60, 25, 45)
    txtLbl.TextXAlignment = Enum.TextXAlignment.Left
    txtLbl.ZIndex = 99
    
    -- Track
    local track = Instance.new("TextButton")
    track.Parent = frame
    track.Size = UDim2.new(1, -20, 0, 16)
    track.Position = UDim2.new(0, 10, 0, 34)
    track.BackgroundColor3 = Color3.fromRGB(255, 195, 210)
    track.BackgroundTransparency = 0.3
    track.Text = ""
    track.ZIndex = 99
    track.AutoButtonColor = false
    track.BorderSizePixel = 0
    
    local trackCorner = Instance.new("UICorner")
    trackCorner.CornerRadius = UDim.new(0, 8)
    trackCorner.Parent = track
    
    -- Fill
    local percent = (default - min) / (max - min)
    local fill = Instance.new("Frame")
    fill.Parent = track
    fill.Size = UDim2.new(percent, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 105, 140)
    fill.ZIndex = 100
    fill.BorderSizePixel = 0
    
    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(0, 8)
    fillCorner.Parent = fill
    
    -- Knob
    local knob = Instance.new("Frame")
    knob.Parent = track
    knob.Size = UDim2.new(0, 20, 0, 20)
    knob.Position = UDim2.new(percent, -10, 0.5, -10)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.ZIndex = 101
    knob.BorderSizePixel = 0
    
    local knobCorner = Instance.new("UICorner")
    knobCorner.CornerRadius = UDim.new(1, 0)
    knobCorner.Parent = knob
    
    local knobStroke = Instance.new("UIStroke")
    knobStroke.Color = Color3.fromRGB(255, 105, 140)
    knobStroke.Thickness = 2
    knobStroke.Parent = knob
    
    -- Logic kéo slider
    local mouse = player:GetMouse()
    local moveConn = nil
    
    local function updateSlider(inputX)
        local absX = track.AbsolutePosition.X
        local absW = track.AbsoluteSize.X
        local relX = math.clamp(inputX - absX, 0, absW)
        local pct = relX / absW
        local value = math.floor(min + (max - min) * pct + 0.5)
        
        fill.Size = UDim2.new(pct, 0, 1, 0)
        knob.Position = UDim2.new(pct, -10, 0.5, -10)
        txtLbl.Text = name .. ": " .. value
        
        callback(value)
    end
    
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            updateSlider(input.Position.X)
            if moveConn then moveConn:Disconnect() end
            moveConn = mouse.Move:Connect(function()
                updateSlider(mouse.X)
            end)
        end
    end)
    
    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if moveConn then moveConn:Disconnect() end
            moveConn = mouse.Move:Connect(function()
                updateSlider(mouse.X)
            end)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if moveConn then moveConn:Disconnect(); moveConn = nil end
        end
    end)
    
    return frame
end


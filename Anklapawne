    local isOn = default or false
    
    if isOn then
        toggleSwitch.BackgroundColor3 = Color3.fromRGB(255, 105, 140)
        dot.Position = UDim2.new(1, -20, 0.5, -8)
    else
        toggleSwitch.BackgroundColor3 = Color3.fromRGB(190, 190, 200)
    end
    
    toggleSwitch.MouseButton1Click:Connect(function()

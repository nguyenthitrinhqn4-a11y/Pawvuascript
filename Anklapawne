-- ESP TIA
local espTiaObjects = {}
function clearEspTia()
    for _, objs in pairs(espTiaObjects) do
        for _, obj in ipairs(objs) do pcall(function() obj:Remove() end) end
    end
    espTiaObjects = {}
end
spawn(function()
    while wait(0.1) do
        if espTiaEnabled then
            pcall(function()
                local myChar = player.Character
                if not myChar or not myChar.PrimaryPart then return end
                for _, other in ipairs(Players:GetPlayers()) do
                    if other ~= player and other.Character and other.Character:FindFirstChild("Head") then
                        if espTiaObjects[other.Name] then
                            for _, obj in ipairs(espTiaObjects[other.Name]) do pcall(function() obj:Remove() end) end
                        end
                        local beam = Instance.new("Beam", workspace)
                        local att0 = Instance.new("Attachment", myChar.PrimaryPart)
                        att0.Position = Vector3.new(0, 2, 0)
                        local att1 = Instance.new("Attachment", other.Character.Head)
                        beam.Attachment0 = att0
                        beam.Attachment1 = att1
                        beam.Color = ColorSequence.new(Color3.fromRGB(0, 255, 0))
                        beam.Width0 = 0.25
                        beam.Width1 = 0.25
                        beam.Transparency = NumberSequence.new(0.15)
                        beam.Enabled = true
                        espTiaObjects[other.Name] = {beam, att0, att1}
                    end
                end
            end)
        end
    end
end)

-- ESP NHÂN VẬT
local espNVObjects = {}
function clearEspNV()
    for _, v in ipairs(espNVObjects) do pcall(function() v:Remove() end) end
    espNVObjects = {}
end
spawn(function()
    while wait(0.3) do
        if espNVEnabled then
            pcall(function()
                clearEspNV()
                for _, other in ipairs(Players:GetPlayers()) do
                    if other ~= player and other.Character and other.Character:FindFirstChild("Head") and other.Character:FindFirstChild("Humanoid") then
                        local char = other.Character
                        local hl = Instance.new("Highlight", char)
                        hl.FillColor = Color3.fromRGB(0, 255, 0)
                        hl.FillTransparency = 0.7
                        hl.OutlineColor = Color3.fromRGB(0, 255, 0)
                        hl.Enabled = true
                        table.insert(espNVObjects, hl)
                        
                        local bb = Instance.new("BillboardGui", char.Head)
                        bb.Size = UDim2.new(0, 180, 0, 50)
                        bb.StudsOffset = Vector3.new(0, 2.5, 0)
                        bb.AlwaysOnTop = true
                        bb.MaxDistance = 800
                        
                        for _, edge in ipairs({"Top","Bottom","Left","Right"}) do
                            local f = Instance.new("Frame", bb)
                            f.BorderSizePixel = 0
                            f.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                            if edge == "Top" then f.Size = UDim2.new(1,0,0,2)
                            elseif edge == "Bottom" then f.Size = UDim2.new(1,0,0,2) f.Position = UDim2.new(0,0,1,-2)

-- AUTO HEAL (FIX - TÌM BĂNG GẠC TRONG BACKPACK)
spawn(function()
    while wait(0.6) do
        if autoHealEnabled then
            pcall(function()
                local char = player.Character
                if not char then return end
                local hum = char:FindFirstChild("Humanoid")
                if not hum or hum.Health <= 0 then return end
                
                -- Nếu HP dưới 65% thì tìm băng gạc
                if hum.Health < hum.MaxHealth * 0.65 then
                    local healTool = nil
                    
                    -- Tìm trong người trước
                    for _, kid in ipairs(char:GetChildren()) do
                        if kid:IsA("Tool") then
                            local n = kid.Name:lower()
                            if n:find("band") or n:find("băng") or n:find("gạc") or n:find("med") or n:find("heal") or n:find("cứu") or n:find("thuốc") then
                                healTool = kid
                                break
                            end
                        end
                    end
                    
                    -- Nếu ko có trên người, tìm trong backpack
                    if not healTool then
                        for _, item in ipairs(player.Backpack:GetChildren()) do
                            if item:IsA("Tool") then
                                local n = item.Name:lower()
                                if n:find("band") or n:find("băng") or n:find("gạc") or n:find("med") or n:find("heal") or n:find("cứu") or n:find("thuốc") then
                                    healTool = item
                                    hum:EquipTool(item)
                                    wait(0.1)
                                    break
                                end
                            end
                        end
                    end
                    
                    -- Kích hoạt
                    if healTool then
                        healTool:Activate()
                    end
                end
            end)
        end
    end
end)

